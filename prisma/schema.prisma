generator client {
  provider = "prisma-client-js"
  // output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
}

// ─────────────────────────────
// ENUMS
// ─────────────────────────────
enum AgentStatus {
  REJECTED
  APPROVED
  PENDING
}

enum IdentityType {
  CNIC
  PASSPORT
}

enum PaymentType {
  ONLINE
  // WALLET
  // CREDIT
  // CASH
}

// ─────────────────────────────
// ROLE
// ─────────────────────────────
model Role {
  id          Int     @id @default(autoincrement())
  name        String
  slug        String  @unique
  description String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
  createdBy Int?
  updatedBy Int?
  deletedBy Int?

  isActive Boolean @default(true)

  users           User[]
  permissions     Permission[]
  agents          Agent[]
  rolePermissions RolePermission[]

  @@map("roles")
}

// ─────────────────────────────
// PERMISSION
// ─────────────────────────────
model Permission {
  id          Int     @id @default(autoincrement())
  name        String
  slug        String
  description String?
  icon        String? @default("House")

  parentId Int?
  parent   Permission?  @relation("PermissionParent", fields: [parentId], references: [id])
  children Permission[] @relation("PermissionParent")

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
  createdBy Int?
  updatedBy Int?
  deletedBy Int?

  isActive Boolean @default(true)

  roleId          Int
  role            Role             @relation(fields: [roleId], references: [id])
  rolePermissions RolePermission[]

  @@unique([roleId, slug])
  @@map("permissions")
}

// ─────────────────────────────
// ROLE PERMISSION
// ─────────────────────────────
model RolePermission {
  id Int @id @default(autoincrement())

  roleId Int
  role   Role @relation(fields: [roleId], references: [id])

  permissionId Int
  permission   Permission @relation(fields: [permissionId], references: [id])

  @@unique([roleId, permissionId])
  @@map("role_permissions")
}

// ─────────────────────────────
// REFRESH TOKEN
// ─────────────────────────────
model RefreshToken {
  id    Int    @id @default(autoincrement())
  token String @unique

  userId Int
  user   User @relation(fields: [userId], references: [id])

  isRevoked Boolean  @default(false)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@map("refresh_tokens")
}

// ─────────────────────────────
// AGENT
// ─────────────────────────────
model Agent {
  id          Int          @id @default(autoincrement())
  fullName    String
  email       String       @unique
  companyName String?
  phone       String?
  cnic        String
  commission  Float?       @default(0)
  paymentType PaymentType?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
  createdBy Int?
  updatedBy Int?
  deletedBy Int?

  approvedBy Int?
  approvedAt DateTime?

  isActive Boolean     @default(true)
  status   AgentStatus @default(PENDING)

  user User[]

  roleId          Int
  role            Role             @relation(fields: [roleId], references: [id])
  psaId           Int?
  psa             Agent?           @relation("PSAtoSubAgent", fields: [psaId], references: [id])
  subAgents       Agent[]          @relation("PSAtoSubAgent")
  agentStatusLogs AgentStatusLog[]

  @@map("agents")
}

// ─────────────────────────────
// AGENT STATUS LOG
// ─────────────────────────────
model AgentStatusLog {
  id        Int         @id @default(autoincrement())
  agentId   Int
  agent     Agent       @relation(fields: [agentId], references: [id])
  status    AgentStatus
  changedBy Int?
  reason    String?

  createdAt DateTime @default(now())

  @@map("agent_status_logs")
}

// ─────────────────────────────
// USER
// ─────────────────────────────
model User {
  id       Int     @id @default(autoincrement())
  fullName String
  email    String  @unique
  password String
  phone    String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
  createdBy Int?
  updatedBy Int?
  deletedBy Int?

  isActive Boolean     @default(true)
  status   AgentStatus @default(PENDING)

  roleId Int
  role   Role @relation(fields: [roleId], references: [id])

  agentId       Int?
  agent         Agent?         @relation(fields: [agentId], references: [id])
  refreshTokens RefreshToken[]

  @@map("users")
}
