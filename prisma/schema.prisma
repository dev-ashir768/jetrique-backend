generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mysql"
}

// ─────────────────────────────
// ENUMS
// ─────────────────────────────
enum AccountStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  REJECTED
  APPROVED
  PENDING
}

enum AgentType {
  INDIVIDUAL_AGENT
  PSA
  SUB_AGENT
}

enum IdentityType {
  CNIC
  PASSPORT
}

// ─────────────────────────────
// ROLE
// ─────────────────────────────
model Role {
  id          Int     @id @default(autoincrement())
  name        String
  slug        String  @unique
  description String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
  createdBy Int?
  updatedBy Int?
  deletedBy Int?

  isActive Boolean @default(true)

  users           User[]
  permissions     Permission[]
  agents          Agent[]
  rolePermissions RolePermission[]

  @@map("roles")
}

// ─────────────────────────────
// PERMISSION
// ─────────────────────────────
model Permission {
  id          Int     @id @default(autoincrement())
  name        String
  slug        String
  description String?
  icon        String? @default("House")

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
  createdBy Int?
  updatedBy Int?
  deletedBy Int?

  isActive Boolean @default(true)

  roleId          Int
  role            Role             @relation(fields: [roleId], references: [id])
  rolePermissions RolePermission[]

  @@unique([roleId, slug])
  @@map("permissions")
}

// ─────────────────────────────
// ROLE PERMISSION
// ─────────────────────────────
model RolePermission {
  id Int @id @default(autoincrement())

  roleId Int
  role   Role @relation(fields: [roleId], references: [id])

  permissionId Int
  permission   Permission @relation(fields: [permissionId], references: [id])

  @@unique([roleId, permissionId])
  @@map("role_permissions")
}

// ─────────────────────────────
// AGENT
// ─────────────────────────────
model Agent {
  id          Int       @id @default(autoincrement())
  fullName    String
  email       String    @unique
  phone       String?
  agentType   AgentType
  companyName String?
  cnic        String

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
  createdBy Int?
  updatedBy Int?
  deletedBy Int?

  isActive Boolean @default(true)

  user User[]

  roleId    Int
  role      Role    @relation(fields: [roleId], references: [id])
  psaId     Int?
  psa       Agent?  @relation("PSAtoSubAgent", fields: [psaId], references: [id])
  subAgents Agent[] @relation("PSAtoSubAgent")

  @@map("agents")
}

// ─────────────────────────────
// USER
// ─────────────────────────────
model User {
  id       Int     @id @default(autoincrement())
  fullName String
  email    String  @unique
  password String
  phone    String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
  createdBy Int?
  updatedBy Int?
  deletedBy Int?

  isActive Boolean       @default(true)
  status   AccountStatus @default(PENDING)

  roleId Int
  role   Role @relation(fields: [roleId], references: [id])

  agentId Int?
  agent   Agent? @relation(fields: [agentId], references: [id])

  @@map("users")
}
